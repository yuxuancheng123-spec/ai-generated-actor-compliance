  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "default": "2026-07-14",
      "title": "Schema Version",
      "type": "string"
    },
    "case_id": {
      "title": "Case Id",
      "type": "string"
    },
    "title": {
      "title": "Title",
      "type": "string"
    },
    "requester": {
      "$ref": "#/$defs/Requester"
    },
    "represented_person": {
      "$ref": "#/$defs/RepresentedPerson"
    },
    "source_media": {
      "$ref": "#/$defs/SourceMedia"
    },
    "intended_use": {
      "$ref": "#/$defs/IntendedUsePlan"
    },
    "consent": {
      "$ref": "#/$defs/ConsentRecordInput"
    },
    "disclosure_plan": {
      "$ref": "#/$defs/DisclosurePlan"
    },
    "provenance_controls": {
      "$ref": "#/$defs/ProvenanceControls"
    },
    "evidence_attachments": {
      "items": {
        "$ref": "#/$defs/EvidenceAttachment"
      },
      "title": "Evidence Attachments",
      "type": "array"
    },
    "reviewer_status": {
      "$ref": "#/$defs/ReviewerStatus",
      "default": "pending"
    },
    "timestamps": {
      "$ref": "#/$defs/TimestampMetadata"
    }
