        "verification_status": {
          "$ref": "#/$defs/VerificationStatus",
          "default": "unknown"
        },
        "retention_until": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
