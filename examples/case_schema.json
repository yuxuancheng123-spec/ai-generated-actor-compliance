        "output_hash_registry": {
          "$ref": "#/$defs/VerificationStatus",
          "default": "unknown"
        },
        "model_version_logged": {
          "$ref": "#/$defs/VerificationStatus",
          "default": "unknown"
        },
        "export_event_logged": {
          "$ref": "#/$defs/VerificationStatus",
          "default": "unknown"
        },
        "vendor_lineage_logged": {
          "$ref": "#/$defs/VerificationStatus",
          "default": "unknown"
