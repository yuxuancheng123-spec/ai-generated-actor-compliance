      },
      "required": [
        "evidence_type"
      ],
      "title": "EvidenceAttachment",
      "type": "object"
    },
    "IntendedUse": {
      "enum": [
        "short_drama",
        "advertisement",
        "virtual_influencer",
        "fan_content",
        "parody",
        "political_message",
        "internal_test",
        "model_training",
        "other"
