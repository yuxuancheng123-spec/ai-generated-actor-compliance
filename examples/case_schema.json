      "type": "string"
    },
    "ReviewerStatus": {
      "enum": [
        "pending",
        "in_review",
        "approved",
        "approved_with_conditions",
        "rejected",
        "archived"
      ],
      "title": "ReviewerStatus",
      "type": "string"
    },
    "SensitiveContext": {
      "enum": [
        "none",
        "sexual",
        "political",
        "medical",
        "financial",
        "defamatory",
        "violence",
        "unknown",
        "not_provided"
      ],
